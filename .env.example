# Server port for the Express app (optional)
# If not set, defaults to 5000
PORT=5000

# Primary: Single connection string for Postgres/Drizzle
# Example for local Postgres:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solarflow
DATABASE_URL=

# Alternative: Individual Postgres variables (used if DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=solarflow

# Vite/React client envs (must start with VITE_ if needed by the browser)
# VITE_API_BASE=/api
